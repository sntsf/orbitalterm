{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OrbitalTerm",
  "version": "0.1.0",
  "identifier": "dev.orbitalterm.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "OrbitalTerm",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "maximized": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libfreerdp-client3-3",
          "libfreerdp3-3",
          "libwinpr3-3",
          "wl-clipboard"
        ]
      }
    },
    "windows": {
      "nsis": {
        "languages": ["Spanish", "English", "French", "Russian", "Japanese"],
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
