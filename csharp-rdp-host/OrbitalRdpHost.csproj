<Project Sdk="Microsoft.NET.Sdk">

  <!--
    OrbitalRdpHost — standalone C# helper that hosts the Microsoft RDP ActiveX
    control (MsRdpClient10/9) using WinForms AxHost. AxHost provides the full
    OLE in-place activation site that our hand-rolled Rust hosting lacked, which
    is what lets ClearTextPassword feed NLA silently (no credential dialog).

    Build:  dotnet build -c Release
    Output: bin/Release/net8.0-windows/OrbitalRdpHost.exe

    Requires the .NET 8 SDK. If you only have the .NET Framework, change
    TargetFramework to net48 and build with msbuild instead.
  -->

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AssemblyName>OrbitalRdpHost</AssemblyName>
    <!-- Match the x64 Tauri host process so HWND reparenting works. -->
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

</Project>
